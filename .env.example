# Database
DB_USER=hms_user
DB_PASSWORD=hms_password
DB_NAME=hms_db
DB_HOST=db
DB_PORT=5432

# FastAPI
SECRET_KEY=your-super-secret-key-change-this-in-production
PII_ENCRYPTION_KEY=32-byte-base64-encoded-key-here-for-aes256
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Service Discovery
SYMPTOM_CHECKER_URL=http://symptom_checker:8001

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@maxcare.local
EMAILS_ENABLED=false

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:5173
